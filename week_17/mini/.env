# -------- Mongo (docker compose auth) --------
MONGO_URI=mongodb://app:app_pw@127.0.0.1:27017/?authSource=admin
MONGO_DB=social_commerce
MONGO_COLLECTION=mini_users

# -------- MySQL (docker compose maps host 3307 -> container 3306) --------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DB=social_commerce
MYSQL_USER=app
MYSQL_PASSWORD=app_pw
MYSQL_POOL_SIZE=5

# -------- Kafka --------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=users.registered
KAFKA_GROUP_ID=user_group

# Kafka KRaft (ONLY for docker-compose kafka container startup)
CLUSTER_ID=SqOr4HxnRJGTnCh7n1uYgQ

# -------- Seed file --------
SEED_FILE_PATH=./data/users.json
POLL_SECONDS=10
